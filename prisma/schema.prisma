generator client {
  provider = "prisma-client"
  output   = "../shared/lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}




enum Plan {
  FREE
  PRO
}

enum Tone {
  PROFESSIONAL
  CONVERSATIONAL
  CONFIDENT
  FRIENDLY
}

enum ProposalFormula {
  AIDA
  PAS
  BAB
  STAR
  DIRECT
}

enum ProposalLength {
  SHORT
  MEDIUM
  LONG
}

enum ProposalStatus {
  REPLIED
  WON
  NO_RESPONSE
}

model User {
  id                   String    @id
  email                String    @unique
  fullName             String?
  plan                 Plan      @default(FREE)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  currentPeriodEnd     DateTime?
  subscriptionStatus   String?
  createdAt            DateTime  @default(now())
  profiles             FreelancerProfile[]
  proposals            Proposal[]
}

model FreelancerProfile {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  skills         String[]  @default([])
  bio            String
  portfolioItems Json      @default("[]")
  isDefault      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  proposals      Proposal[]

  @@index([userId])
}

model Proposal {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileId        String
  profile          FreelancerProfile @relation(fields: [profileId], references: [id])
  jobTitle         String
  jobUrl           String?
  jobDescription   String
  tone             Tone
  formula          ProposalFormula
  proposalLength   ProposalLength
  upworkOpener     Boolean   @default(false)
  generatedContent String
  editedContent    String?
  status           ProposalStatus?
  createdAt        DateTime  @default(now())

  @@index([userId])
  @@index([userId, createdAt])
}
