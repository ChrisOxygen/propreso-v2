// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../shared/lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}




enum Plan {
  FREE
  PRO
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum GenerationStatus {
  COMPLETED
  FAILED
}

enum Tone {
  PROFESSIONAL
  CONVERSATIONAL
  CONFIDENT
  FRIENDLY
}

enum ProposalStatus {
  REPLIED
  WON
  NO_RESPONSE
}

model User {
  id                   String           @id
  email                String           @unique
  fullName             String?
  plan                 Plan             @default(FREE)
  tokenBalance         Int              @default(10)
  billingInterval      BillingInterval?
  stripeCustomerId     String?          @unique
  stripeSubscriptionId String?          @unique
  stripePriceId        String?
  currentPeriodEnd     DateTime?
  subscriptionStatus   String?
  createdAt            DateTime         @default(now())
  profiles             FreelancerProfile[]
  proposals            Proposal[]
  generationEvents     GenerationEvent[]
}

model FreelancerProfile {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  skills         String[]  @default([])
  bio            String
  portfolioItems Json      @default("[]")
  isDefault      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  proposals      Proposal[]

  @@index([userId])
}

model Proposal {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileId        String
  profile          FreelancerProfile @relation(fields: [profileId], references: [id])
  jobDescription   String
  tone             Tone
  signals          Json?
  wordCount        Int?
  generatedContent String
  editedContent    String?
  status           ProposalStatus?
  createdAt        DateTime  @default(now())

  @@index([userId])
  @@index([userId, createdAt])
}

model GenerationEvent {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    GenerationStatus @default(COMPLETED)
  jobTitle  String?
  createdAt DateTime         @default(now())

  @@index([userId, createdAt])
}
